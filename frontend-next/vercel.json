{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend-next/package.json",
      "use": "@vercel/next"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "api/index.py" },
    { "source": "/auth/(.*)", "destination": "api/index.py" },
    { "source": "/(.*)", "destination": "/frontend-next/$1" }
  ]
}
